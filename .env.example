# Public URL of this app (no trailing slash)
APP_URL=https://pay.synepic.com

# Pesapal — reuse the Synepic merchant account credentials
PESAPAL_ENVIRONMENT=production
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# Obtained once after deploy via `npm run register-ipn` (see README)
PESAPAL_NOTIFICATION_ID=
PESAPAL_CURRENCY=UGX
PESAPAL_COUNTRY_CODE=UG

# Package amounts (ugx)
DEPOSIT_AMOUNT=175000
BALANCE_AMOUNT=175000

# Brand shown on the page + in the Pesapal billing_address placeholder
BRAND_NAME=Synepic
BRAND_EMAIL=analytics.synepic@gmail.com
WHATSAPP_NUMBER=256759799619

# Used only by scripts/register-ipn.mjs (run once after the app is live)
IPN_URL=https://pay.synepic.com/api/pesapal/ipn
IPN_METHOD=GET